/* pages/chat/chat.wxss */

/* P0-1: 隐私告知条 (视频 1 反馈) */
.privacy-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff7e6;
  border-left: 6rpx solid #d4a574;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #6b5237;
  line-height: 1.5;
}
.privacy-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.privacy-text {
  flex: 1;
}

.messages {
  padding: 16rpx 0;
  height: 60vh;
  background: #f5f0e8;
}

.msg {
  margin: 16rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  max-width: 80%;
  word-break: break-word;
  white-space: pre-wrap;
}

.msg-user {
  background: #1F3A5F;
  color: #ffffff;
  margin-left: auto;
}

.msg-bot {
  background: #ffffff;
  color: #1a1a1a;
  border: 2rpx solid #d4c5a9;
}

.msg-role-tag {
  font-size: 22rpx;
  color: #8b7355;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.msg-content {
  font-size: 30rpx;
  line-height: 1.7;
}

.typing-cursor {
  display: inline-block;
  animation: blink 1s infinite;
  color: #8b7355;
  font-weight: 700;
  margin-left: 4rpx;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* 角色选择 — P0-3: 滑动提示 (视频 2 反馈) */
.role-row-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.role-row {
  white-space: nowrap;
  padding: 16rpx 0;
  background: #f5f0e8;
  display: flex;
  flex-wrap: nowrap;
}

.role-row-hint {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 80rpx;
  background: linear-gradient(to right, rgba(245, 240, 232, 0), rgba(245, 240, 232, 1));
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.role-row-arrow {
  font-size: 48rpx;
  color: #8b7355;
  font-weight: 700;
  line-height: 1;
  animation: arrowHint 1.6s ease-in-out infinite;
}

@keyframes arrowHint {
  0%, 100% { transform: translateX(0); opacity: 0.7; }
  50% { transform: translateX(8rpx); opacity: 1; }
}

.role-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  background: #ffffff;
  border: 2rpx solid #d4c5a9;
  border-radius: 16rpx;
  transition: all 200ms;
}

.role-active {
  background: #1F3A5F;
  color: #ffffff;
  border-color: #1F3A5F;
  transform: scale(1.05);
}

.role-icon {
  font-size: 32rpx;
}

.role-name {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.role-clear {
  border-color: #d4c5a9;
  background: #faf6ec;
}

/* 输入 */
.input-bar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0;
  border-top: 2rpx solid #d4c5a9;
  background: #ffffff;
  position: sticky;
  bottom: 0;
}

.input {
  flex: 1;
  background: #faf6ec;
  border: 2rpx solid #d4c5a9;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.btn-send {
  background: #1F3A5F;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  line-height: 64rpx;
  border: none;
}

.btn-send[disabled] {
  background: #8b7355;
  opacity: 0.6;
}
