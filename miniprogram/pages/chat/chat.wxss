/* pages/chat/chat.wxss */
.messages {
  padding: 16rpx 0;
  height: 60vh;
  background: #f5f0e8;
}

.msg {
  margin: 16rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  max-width: 80%;
  word-break: break-word;
  white-space: pre-wrap;
}

.msg-user {
  background: #1F3A5F;
  color: #ffffff;
  margin-left: auto;
}

.msg-bot {
  background: #ffffff;
  color: #1a1a1a;
  border: 2rpx solid #d4c5a9;
}

.msg-role-tag {
  font-size: 22rpx;
  color: #8b7355;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.msg-content {
  font-size: 30rpx;
  line-height: 1.7;
}

.typing-cursor {
  display: inline-block;
  animation: blink 1s infinite;
  color: #8b7355;
  font-weight: 700;
  margin-left: 4rpx;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* 角色选择 */
.role-row {
  white-space: nowrap;
  padding: 16rpx 0;
  background: #f5f0e8;
  display: flex;
  flex-wrap: nowrap;
}

.role-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  background: #ffffff;
  border: 2rpx solid #d4c5a9;
  border-radius: 16rpx;
  transition: all 200ms;
}

.role-active {
  background: #1F3A5F;
  color: #ffffff;
  border-color: #1F3A5F;
  transform: scale(1.05);
}

.role-icon {
  font-size: 32rpx;
}

.role-name {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.role-clear {
  border-color: #d4c5a9;
  background: #faf6ec;
}

/* 输入 */
.input-bar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0;
  border-top: 2rpx solid #d4c5a9;
  background: #ffffff;
  position: sticky;
  bottom: 0;
}

.input {
  flex: 1;
  background: #faf6ec;
  border: 2rpx solid #d4c5a9;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.btn-send {
  background: #1F3A5F;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  line-height: 64rpx;
  border: none;
}

.btn-send[disabled] {
  background: #8b7355;
  opacity: 0.6;
}
